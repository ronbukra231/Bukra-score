# ── Bukra Capital — Backend Environment Variables ─────────────────────────────

# AI explanations (required for Hebrew company analysis)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# CORS — comma-separated list of allowed frontend origins
# Local dev default: http://localhost:5173
# Production: add your Vercel URL
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Optional: override the data directory path (defaults to backend/data/)
# DATA_DIR=/data

# ── Portfolio Simulator authentication (services/auth.py) ─────────────────────
# Verifies the Authorization: Bearer <token> header Supabase issues to signed-
# in users. Supabase projects sign tokens one of two ways — configure the one
# that matches this Supabase project (Project Settings → API):
#
#   Legacy shared secret (HS256):
#     SUPABASE_JWT_SECRET=your_supabase_jwt_secret   # "JWT Secret" field
#
#   Newer asymmetric signing keys (RS256/ES256, verified via JWKS):
#     SUPABASE_URL=https://<project-ref>.supabase.co  # Project URL
#
# Set whichever one matches the project; the backend picks the correct
# verification path per-token automatically. Without at least one of these,
# every Portfolio Simulator API request returns 503.
# SUPABASE_JWT_SECRET=
# SUPABASE_URL=

# Optional — only if the Supabase project uses a non-default JWT audience:
# SUPABASE_JWT_AUDIENCE=authenticated
